# Optional deployment environment variables
JAWDAH_HOST=0.0.0.0
# Railway injects PORT automatically. Locally you may use:
JAWDAH_PORT=8765
# Persistent data path on Railway (mount a volume at /app/data)
JAWDAH_DATA_DIR=/app/data
# Optional direct database path
# JAWDAH_DB_PATH=/app/data/jawdah.sqlite3
# CORS for GitHub Pages frontend calling Railway API (use * or your pages URL)
JAWDAH_CORS_ORIGIN=*
