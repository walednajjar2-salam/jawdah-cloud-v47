# Railway / production
JAWDAH_HOST=0.0.0.0
# Railway sets PORT automatically
JAWDAH_DATA_DIR=/app/data
# JAWDAH_DB_PATH=/app/data/jawdah.sqlite3
# JAWDAH_CORS_ORIGIN=*

# Automatic backup (enabled by default)
# JAWDAH_AUTO_BACKUP=1
# JAWDAH_BACKUP_INTERVAL_HOURS=24
# JAWDAH_BACKUP_RETENTION=30
# JAWDAH_BACKUP_DIR=/app/data/backups

# Local development
# JAWDAH_PORT=8765
# JAWDAH_DATA_DIR=./data
